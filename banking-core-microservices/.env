# Banking Core Microservices — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# All ports are overridable without touching application code.
#
# Docker   : edit this file, then run  start-services.bat
# Local JVM: set OS env vars  or pass  -DACCOUNT_SERVICE_PORT=9081
#
# See docs/Implementation-Notes.html #1 for the full port-override strategy.
# ─────────────────────────────────────────────────────────────────────────────

# ── Infrastructure ────────────────────────────────────────────────────────────
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFDROP_PORT=9000
POSTGRES_PORT=5432

# ── Spring Boot Services ──────────────────────────────────────────────────────
CONFIG_SERVER_PORT=8888
REGISTRY_PORT=8761
GATEWAY_PORT=8090
ACCOUNT_SERVICE_PORT=8081
TRANSACTION_SERVICE_PORT=8082
# notification-service: no port — WebApplicationType.NONE (pure Kafka consumer)

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Services currently use H2 in-memory (dev default).
# To switch to PostgreSQL: activate a 'docker' Spring profile per service and
# provide these values as env vars in the service container.
POSTGRES_DB=banking_db
POSTGRES_USER=banking_user
POSTGRES_PASSWORD=banking_pass
